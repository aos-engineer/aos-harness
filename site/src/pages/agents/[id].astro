---
import Base from '../../layouts/Base.astro';
import { loadAllAgents } from '../../lib/content';

export function getStaticPaths() {
  const agents = loadAllAgents();
  return agents.map(agent => ({
    params: { id: agent.id },
    props: { agent },
  }));
}

const { agent } = Astro.props;

const categoryColors = {
  orchestrator: 'var(--color-orchestrator)',
  perspective: 'var(--color-perspective)',
  operational: 'var(--color-operational)',
};
---

<Base title={agent.name} description={agent.cognition.objective_function}>
  <div class="px-6 py-12">
    <div class="mx-auto max-w-4xl">
      <!-- Breadcrumb -->
      <div class="text-sm text-[var(--color-text-muted)] mb-6">
        <a href="/agents" class="hover:text-white">Agents</a> &rarr; {agent.name}
      </div>

      <!-- Header -->
      <div class="flex items-center gap-3 mb-2">
        <span class="w-3 h-3 rounded-full" style={`background: ${categoryColors[agent.category]}`}></span>
        <h1 class="text-4xl font-bold text-white">{agent.name}</h1>
      </div>
      <p class="text-lg text-[var(--color-text-muted)] mb-8">{agent.role}</p>

      <!-- Cognitive Framework -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-white mb-4">Cognitive Framework</h2>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Objective Function</dt>
              <dd class="mt-1 text-white">{agent.cognition.objective_function}</dd>
            </div>
            <div>
              <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Core Bias</dt>
              <dd class="mt-1 text-white">{agent.cognition.core_bias}</dd>
            </div>
            <div>
              <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Risk Tolerance</dt>
              <dd class="mt-1 text-white">{agent.cognition.risk_tolerance}</dd>
            </div>
            <div>
              <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Default Stance</dt>
              <dd class="mt-1 text-white italic">"{agent.cognition.default_stance}"</dd>
            </div>
          </dl>

          <div class="mt-4 pt-4 border-t border-[var(--color-border)]">
            <dt class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Time Horizon</dt>
            <div class="flex gap-4">
              <div>
                <span class="text-xs text-[var(--color-accent)]">Primary</span>
                <p class="text-sm text-white">{agent.cognition.time_horizon.primary}</p>
              </div>
              <div>
                <span class="text-xs text-[var(--color-text-muted)]">Secondary</span>
                <p class="text-sm text-white">{agent.cognition.time_horizon.secondary}</p>
              </div>
              <div>
                <span class="text-xs text-[var(--color-text-muted)]">Peripheral</span>
                <p class="text-sm text-white">{agent.cognition.time_horizon.peripheral}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Heuristics -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-white mb-4">Heuristics</h2>
        <div class="space-y-3">
          {agent.persona.heuristics.map(h => (
            <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
              <h3 class="font-semibold text-white mb-1">{h.name}</h3>
              <p class="text-sm text-[var(--color-text-muted)]">{h.rule}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Thinking Patterns -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-white mb-4">Thinking Patterns</h2>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <ul class="space-y-2">
            {agent.persona.thinking_patterns.map(pattern => (
              <li class="text-sm text-[var(--color-text-muted)] flex items-start gap-2">
                <span class="text-[var(--color-accent)] mt-0.5">&bull;</span>
                <span class="italic">"{pattern}"</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Evidence Standard -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-white mb-4">Evidence Standard</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
            <h3 class="text-sm font-semibold text-[var(--color-success)] mb-2">Convinced By</h3>
            <ul class="space-y-1">
              {(agent.persona.evidence_standard?.convinced_by ?? agent.persona.evidence_standard?.convincing ?? []).map(item => (
                <li class="text-sm text-[var(--color-text-muted)]">+ {item}</li>
              ))}
            </ul>
          </div>
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
            <h3 class="text-sm font-semibold text-[var(--color-danger)] mb-2">Not Convinced By</h3>
            <ul class="space-y-1">
              {(agent.persona.evidence_standard?.not_convinced_by ?? agent.persona.evidence_standard?.unconvincing ?? []).map(item => (
                <li class="text-sm text-[var(--color-text-muted)]">- {item}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Red Lines -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-white mb-4">Red Lines</h2>
        <div class="bg-[var(--color-surface)] border border-[var(--color-danger)]/30 rounded-lg p-4">
          <ul class="space-y-2">
            {agent.persona.red_lines.map(line => (
              <li class="text-sm text-[var(--color-text-muted)] flex items-start gap-2">
                <span class="text-[var(--color-danger)]">&cross;</span>
                <span>{line}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Tensions -->
      {agent.tensions.length > 0 && (
        <section class="mb-10">
          <h2 class="text-2xl font-bold text-white mb-4">Tension Pairs</h2>
          <div class="space-y-3">
            {agent.tensions.map(t => (
              <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-semibold text-white">{agent.name}</span>
                  <span class="text-[var(--color-accent)]">&harr;</span>
                  <a href={`/agents/${t.agent}`} class="font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]">{t.agent}</a>
                </div>
                <p class="text-sm text-[var(--color-text-muted)]">{t.dynamic}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Model -->
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-white mb-4">Model Configuration</h2>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 inline-flex gap-6">
          <div>
            <span class="text-xs text-[var(--color-text-muted)]">Tier</span>
            <p class="text-white">{agent.model.tier}</p>
          </div>
          <div>
            <span class="text-xs text-[var(--color-text-muted)]">Thinking</span>
            <p class="text-white">{agent.model.thinking}</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</Base>
