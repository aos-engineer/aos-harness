---
import Base from '../layouts/Base.astro';
import { loadAllAgents, loadAllProfiles, loadAllDomains, loadAllSkills } from '../lib/content';

const agents = loadAllAgents();
const profiles = loadAllProfiles();
const domains = loadAllDomains();
const skills = loadAllSkills();
---

<Base title="AOS Framework">
  <!-- Hero -->
  <section class="px-6 py-20 text-center">
    <div class="mx-auto max-w-4xl">
      <h1 class="text-5xl font-bold leading-tight text-white">
        Train AI agents to think like<br />
        <span class="text-[var(--color-accent)]">your best advisors</span>
      </h1>
      <p class="mt-6 text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto">
        AOS Framework is a config-driven orchestration system for multi-agent AI workflows.
        Assemble advisory councils for strategic deliberation, or orchestrate execution teams
        that produce architecture, task breakdowns, and implementation plans.
      </p>
      <div class="mt-10 flex gap-4 justify-center">
        <a href="/docs/getting-started" class="bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white px-6 py-3 rounded-lg font-medium transition-colors">
          Get Started
        </a>
        <a href="/agents" class="border border-[var(--color-border)] hover:border-[var(--color-accent)] text-white px-6 py-3 rounded-lg font-medium transition-colors">
          Explore Agents
        </a>
      </div>

      <!-- Quick start snippet -->
      <div class="mt-12 text-left max-w-lg mx-auto">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4">
          <p class="text-xs text-[var(--color-text-muted)] mb-2">Get started in 60 seconds</p>
          <pre class="!bg-transparent !border-0 !p-0 text-sm"><code><span class="text-[var(--color-success)]">$</span> bunx @aos-framework/cli init --adapter pi
<span class="text-[var(--color-success)]">$</span> aos run strategic-council --brief your-decision.md
<span class="text-[var(--color-success)]">$</span> aos run cto-execution --brief your-feature.md</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="text-4xl font-bold text-white">{agents.length}</div>
        <div class="mt-2 text-[var(--color-text-muted)]">Cognitive Agents</div>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">
          Each with unique biases, heuristics, and red lines
        </p>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-white">{profiles.length}</div>
        <div class="mt-2 text-[var(--color-text-muted)]">Orchestration Profiles</div>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">
          Deliberation councils and execution teams
        </p>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-white">{skills.length}</div>
        <div class="mt-2 text-[var(--color-text-muted)]">Skills</div>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">
          Reusable capabilities like code review, security scan, and task breakdown
        </p>
      </div>
      <div class="text-center">
        <div class="text-4xl font-bold text-white">{domains.length}</div>
        <div class="mt-2 text-[var(--color-text-muted)]">Domain Packs</div>
        <p class="mt-1 text-sm text-[var(--color-text-muted)]">
          SaaS, healthcare, fintech, platform engineering, personal decisions
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-3xl font-bold text-white text-center mb-12">How It Works</h2>

      <!-- Deliberation Flow -->
      <h3 class="text-lg font-semibold text-blue-400 mb-4">Deliberation Mode</h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">1</div>
          <h3 class="text-lg font-semibold text-white mb-2">Write a Brief</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Describe your strategic problem with situation, stakes, constraints, and a key question.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">2</div>
          <h3 class="text-lg font-semibold text-white mb-2">Choose a Council</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Select a deliberation profile. Each defines which agents participate and how they interact.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">3</div>
          <h3 class="text-lg font-semibold text-white mb-2">Agents Deliberate</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            The Arbiter orchestrates structured debate. Agents challenge each other from distinct cognitive frameworks.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">4</div>
          <h3 class="text-lg font-semibold text-white mb-2">Get a Memo</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Receive ranked recommendations with documented dissent, trade-offs, and next actions.
          </p>
        </div>
      </div>

      <!-- Execution Flow -->
      <h3 class="text-lg font-semibold text-emerald-400 mb-4">Execution Mode</h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-emerald-400 mb-2">1</div>
          <h3 class="text-lg font-semibold text-white mb-2">Submit a Feature</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Describe your feature, product change, or initiative with context and success criteria.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-emerald-400 mb-2">2</div>
          <h3 class="text-lg font-semibold text-white mb-2">Workflow Executes</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            The CTO orchestrator delegates to agents in sequence: requirements, architecture, planning, tasks.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-emerald-400 mb-2">3</div>
          <h3 class="text-lg font-semibold text-white mb-2">Review Gates</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Approve or redirect at key checkpoints. Each phase produces artifacts that feed the next.
          </p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <div class="text-2xl font-bold text-emerald-400 mb-2">4</div>
          <h3 class="text-lg font-semibold text-white mb-2">Execution Package</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Get architecture docs, phase plans, task breakdowns, and risk assessments ready for handoff.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Agent Preview -->
  <section class="px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold text-white">The Agents</h2>
        <a href="/agents" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] text-sm">
          View all {agents.length} agents &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {agents.slice(0, 8).map(agent => (
          <a href={`/agents/${agent.id}`} class="block bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 hover:border-[var(--color-accent)] transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <span class={`w-2 h-2 rounded-full ${
                agent.category === 'orchestrator' ? 'bg-[var(--color-orchestrator)]' :
                agent.category === 'perspective' ? 'bg-[var(--color-perspective)]' :
                'bg-[var(--color-operational)]'
              }`}></span>
              <span class="font-semibold text-white">{agent.name}</span>
            </div>
            <p class="text-xs text-[var(--color-text-muted)] mb-2">{agent.cognition.core_bias}</p>
            <p class="text-sm text-[var(--color-text-muted)] line-clamp-2">{agent.cognition.objective_function}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="px-6 py-16 border-t border-[var(--color-border)]">
    <div class="mx-auto max-w-6xl text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Multi-Platform</h2>
      <p class="text-[var(--color-text-muted)] mb-8">One framework, multiple adapters. Same agents, same profiles, any platform.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <h3 class="font-semibold text-white mb-1">Pi CLI</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Full runtime adapter with TUI, real-time constraint tracking, and streaming.</p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <h3 class="font-semibold text-white mb-1">Claude Code</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Code generator producing .claude/ agents and commands.</p>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
          <h3 class="font-semibold text-white mb-1">Gemini CLI</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Code generator producing .gemini/ agents and settings.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-20 text-center">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to orchestrate your AI team?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">
        Start with the built-in Strategic Council for deliberation,
        or the CTO Execution Profile for production planning.
      </p>
      <a href="/docs/getting-started" class="bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white px-8 py-3 rounded-lg font-medium transition-colors inline-block">
        Get Started
      </a>
    </div>
  </section>
</Base>
