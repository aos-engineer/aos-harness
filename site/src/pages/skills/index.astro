---
import Base from '../../layouts/Base.astro';
import { loadAllSkills, loadAllAgents } from '../../lib/content';

const skills = loadAllSkills();
const agents = loadAllAgents();
const agentMap = new Map(agents.map(a => [a.id, a]));
---

<Base title="Skills Gallery" description="Reusable agent capabilities for code review, security scanning, task decomposition, and more">
  <div class="px-6 py-12">
    <div class="mx-auto max-w-6xl">
      <h1 class="text-4xl font-bold text-white mb-2">Skills Gallery</h1>
      <p class="text-[var(--color-text-muted)] mb-12">
        {skills.length} reusable capabilities that agents can perform within execution workflows.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skills.map(skill => (
          <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6">
            <h2 class="text-xl font-bold text-white mb-2">{skill.name}</h2>
            <p class="text-sm text-[var(--color-text-muted)] mb-4">{skill.description}</p>

            <!-- Inputs -->
            {(skill.input.required?.length || skill.input.optional?.length) && (
              <div class="mb-4">
                <h3 class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Inputs</h3>
                <div class="space-y-1">
                  {skill.input.required?.map((inp: any) => (
                    <div class="flex items-center gap-2 text-xs">
                      <span class="px-1.5 py-0.5 rounded bg-[var(--color-accent)]/10 text-[var(--color-accent)]">required</span>
                      <span class="text-white font-mono">{inp.id}</span>
                      <span class="text-[var(--color-text-muted)]">({inp.type})</span>
                    </div>
                  ))}
                  {skill.input.optional?.map((inp: any) => (
                    <div class="flex items-center gap-2 text-xs">
                      <span class="px-1.5 py-0.5 rounded bg-[var(--color-bg)] text-[var(--color-text-muted)]">optional</span>
                      <span class="text-white font-mono">{inp.id}</span>
                      <span class="text-[var(--color-text-muted)]">({inp.type})</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <!-- Outputs -->
            {skill.output.artifacts?.length && (
              <div class="mb-4">
                <h3 class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Outputs</h3>
                <div class="space-y-1">
                  {skill.output.artifacts.map((art: any) => (
                    <div class="flex items-center gap-2 text-xs">
                      <span class="text-white font-mono">{art.id}</span>
                      <span class="text-[var(--color-text-muted)]">({art.format})</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <!-- Compatible Agents -->
            {skill.compatible_agents.length > 0 && (
              <div class="pt-4 border-t border-[var(--color-border)]">
                <h3 class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Compatible Agents</h3>
                <div class="flex gap-1 flex-wrap">
                  {skill.compatible_agents.map((agentId: string) => {
                    const agent = agentMap.get(agentId);
                    return (
                      <a href={`/agents/${agentId}`} class="text-xs px-2 py-0.5 rounded bg-[var(--color-accent)]/10 text-[var(--color-accent)] hover:bg-[var(--color-accent)]/20 transition-colors">
                        {agent?.name ?? agentId}
                      </a>
                    );
                  })}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Base>
