---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'AOS Framework — Train AI agents to think like your best advisors' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | AOS.engineer</title>
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)]">
    <nav class="border-b border-[var(--color-border)] px-6 py-4">
      <div class="mx-auto max-w-6xl flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-white">
          AOS<span class="text-[var(--color-accent)]">.engineer</span>
        </a>
        <div class="flex gap-6 text-sm">
          <a href="/agents" class="text-[var(--color-text-muted)] hover:text-white transition-colors">Agents</a>
          <a href="/profiles" class="text-[var(--color-text-muted)] hover:text-white transition-colors">Profiles</a>
          <a href="/domains" class="text-[var(--color-text-muted)] hover:text-white transition-colors">Domains</a>
          <a href="/docs/getting-started" class="text-[var(--color-text-muted)] hover:text-white transition-colors">Docs</a>
          <a href="https://github.com/aos-framework/aos-framework" class="text-[var(--color-text-muted)] hover:text-white transition-colors" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] px-6 py-8 mt-16">
      <div class="mx-auto max-w-6xl text-center text-sm text-[var(--color-text-muted)]">
        <p>AOS Framework &mdash; Agentic Orchestration System</p>
        <p class="mt-1">Open source. Config-driven. Multi-platform.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
